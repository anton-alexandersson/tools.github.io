{
   "manifest_version": 3,
   "name": "Table Cell Selector",
   "version": "1.0",
   "description": "Click and drag to select table cells, then Ctrl+C to copy.",
   "permissions": ["clipboardWrite"],
   "content_scripts": [
      {
         "matches": ["<all_urls>"],
         "js": ["content.js"],
         "css": ["styles.css"]
      }
   ]
}